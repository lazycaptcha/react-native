{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "declaration": true,
        "outDir": "dist",
        "lib": ["ES2020"],
        "types": ["jest", "react-native"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "tests"]
}
