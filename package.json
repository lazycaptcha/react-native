{
    "name": "@lazycaptcha/react-native",
  "version": "2.0.0",
    "description": "React Native SDK for LazyCaptcha — self-hostable CAPTCHA. Works on iOS and Android via WebView.",
    "keywords": ["react-native", "captcha", "lazycaptcha", "bot-protection", "ios", "android"],
    "license": "MIT",
    "homepage": "https://lazycaptcha.com",
    "main": "./dist/index.js",
    "module": "./dist/index.esm.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.esm.js",
            "require": "./dist/index.js"
        }
    },
    "files": ["dist", "README.md", "LICENSE"],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
        "test": "jest",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": ">=17.0.0",
        "react-native": ">=0.70.0",
        "react-native-webview": ">=11.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/jest": "^29.5.0",
        "jest": "^29.7.0",
        "react": "^18.2.0",
        "react-native": "^0.73.0",
        "react-native-webview": "^13.6.0",
        "tsup": "^8.0.1",
        "typescript": "^5.3.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
